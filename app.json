{
  "expo": {
    "name": "kids-app",
    "slug": "kids-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "kidsapp",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourstudio.kidsapp"
    },
    "android": {
      "package": "com.yourstudio.kidsapp",
      "adaptiveIcon": {
        "backgroundColor": "#2E2BA6"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
